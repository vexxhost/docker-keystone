+name: dict[str, Any] = {
+    "type": "string",
+    "minLength": 1,
+    "maxLength": 255,
+    "pattern": r"[\S]+",
+}
+
+boolean = {
+    "type": ["boolean", "string"],
+    "enum": [
+        True,
+        "True",
+        "TRUE",
+        "true",
+        False,
+        "False",
+        "FALSE",
+        "false",
+    ],
+}
+
+
+domain_id: dict[str, str] = {
+    "type": "string",
+}
+
+parent_id: dict[str, str] = {"type": "string", "format": "uuid"}
+
+_tag_name_property = {
+    "type": "string",
+    "minLength": 1,
+    "maxLength": 255,
+    # NOTE(gagehugo) This pattern is for tags which follows the
+    # guidelines as set by the API-WG, which matches anything that
+    # does not contain a '/' or ','.
+    # https://specs.openstack.org/openstack/api-wg/guidelines/tags.html
+    "pattern": "^[^,/]*$",
+}
+
+tags: dict[str, Any] = {
+    "type": "string",
+    "x-openstack": {
+        # As OpenAPI request parameters this is an array of string serialized
+        # as csv
+        "openapi": {
+            "schema": {
+                "type": "array",
+                "items": _tag_name_property,
+            },
+            "style": "form",
+            "explode": False,
+        }
+    },
+}
