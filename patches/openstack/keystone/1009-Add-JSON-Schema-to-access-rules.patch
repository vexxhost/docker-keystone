+        ),
+    },
+    "method": {
+        "type": "string",
+        "enum": ["DELETE", "GET", "HEAD", "PATCH", "POST", "PUT"],
+        "description": (
+            "The request method that the application credential is "
+            "permitted to use for a given API endpoint."
+        ),
+    },
+}
